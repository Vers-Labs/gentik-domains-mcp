{
  "name": "gentik-domains-mcp",
  "version": "0.1.0",
  "description": "MCP server for AgentDomains — register domains, check availability, manage DNS, and authenticate via Ed25519",
  "type": "module",
  "bin": {
    "gentik-domains-mcp": "build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "dev": "tsc --watch",
    "start": "node build/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "gentik",
    "domains",
    "dns",
    "ai-agents",
    "ed25519"
  ],
  "author": "Gentik <hello@gentik.io>",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=18"
  }
}
